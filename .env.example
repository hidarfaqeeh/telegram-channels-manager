# Telegram API credentials - احصل عليها من my.telegram.org
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
PHONE_NUMBER=+1234567890
SESSION_NAME=userbot_session

# Admin IDs - معرفات المديرين مفصولة بفواصل
ADMIN_IDS=123456789,987654321

# Control Bot Token - توكن البوت المساعد للتحكم
CONTROL_BOT_TOKEN=your_control_bot_token_here

# Database
DATABASE_URL=sqlite:///bot_database.db

# Bot settings
DEFAULT_TIMEZONE=UTC
MAX_MESSAGE_LENGTH=4096
MAX_CAPTION_LENGTH=1024

# Message formatting
DEFAULT_HEADER=
DEFAULT_FOOTER=
DEFAULT_BUTTONS=[]

# Translation
DEFAULT_TRANSLATE_LANGUAGE=ar
TRANSLATE_SERVICE=google

# Logging
LOG_LEVEL=INFO
LOG_FILE=bot.log

# Rate limiting
INVITE_ACCEPT_RATE=10
MESSAGE_DELAY=1.0

# Auto-accept settings
AUTO_ACCEPT_DELAY=300